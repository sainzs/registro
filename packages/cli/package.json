{
  "name": "@awr/cli",
  "version": "0.4.0",
  "private": true,
  "description": "Agent Work Report CLI",
  "type": "module",
  "bin": {
    "agent-work-report": "./dist/src/cli.js"
  },
  "scripts": {
    "dev": "bun src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/src/cli.js",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "test:bun": "bun test"
  },
  "keywords": [
    "agent",
    "cli",
    "bun",
    "typescript",
    "tui"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2"
  }
}
